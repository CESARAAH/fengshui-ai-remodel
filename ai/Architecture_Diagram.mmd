graph TB
    subgraph Client["🌐 Frontend (React + Vite + Tailwind)"]
        Landing[Landing Page<br/>Hero + Navbar]
        Auth[Auth Page<br/>Sign Up / Login]
        Onboard[Onboarding Flow<br/>4 Steps]
        Dash[Dashboard<br/>Projects + Renders]
        Upload[ImageUpload<br/>Component]
    end

    subgraph Cloud["☁️ Lovable Cloud (Backend)"]
        subgraph AuthSvc["🔐 Authentication"]
            AuthAPI[Email/Password Auth]
        end

        subgraph DB["🗄️ PostgreSQL Database"]
            Projects[(projects<br/>name, type,<br/>investment, status)]
            Images[(project_images<br/>storage_path,<br/>image_type)]
            RLS{{RLS Policies<br/>user_id = auth.uid}}
        end

        subgraph Storage["📦 Object Storage"]
            Bucket[project-images bucket<br/>user_id/project_id/file]
        end

        subgraph Edge["⚡ Edge Functions"]
            GenFn[generate-feng-shui-render<br/>Deno function]
        end
    end

    subgraph AI["🤖 Lovable AI Gateway"]
        Gemini[google/gemini-2.5-<br/>flash-image-preview]
    end

    Landing --> Auth
    Auth -->|Sign in| AuthAPI
    AuthAPI --> Onboard
    Onboard -->|Steps 1-3: Project data| Projects
    Onboard -->|Step 4: Photos/Plans| Upload
    Upload -->|Upload files| Bucket
    Upload -->|Save references| Images
    Onboard --> Dash
    Dash -->|List projects| Projects
    Dash -->|Trigger render| GenFn

    GenFn -->|Read project| Projects
    GenFn -->|Read images| Images
    GenFn -->|Generate prompt + call| Gemini
    Gemini -->|Base64 PNG| GenFn
    GenFn -->|Upload render| Bucket
    GenFn -->|Insert render row| Images
    GenFn -.->|Response| Dash

    Projects -.enforces.-> RLS
    Images -.enforces.-> RLS

    classDef frontend fill:#dbeafe,stroke:#2563eb,color:#1e3a8a
    classDef backend fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef ai fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef db fill:#fce7f3,stroke:#db2777,color:#831843

    class Landing,Auth,Onboard,Dash,Upload frontend
    class AuthAPI,GenFn,Bucket backend
    class Projects,Images,RLS db
    class Gemini ai
